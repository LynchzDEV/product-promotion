<div class="mx-auto md:w-2/3 w-full flex">
  <div class="mx-auto">
    <% if notice.present? %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice">
        <%= notice %>
      </p>
    <% end %>

    <div class="bg-white rounded-lg shadow-lg p-8">
      <h1 class="font-bold text-3xl mb-2"><%= @product.name %></h1>

      <p class="text-sm text-gray-500 mb-6">Product ID: <%= @product.id %></p>

      <%= render 'price_display', product: @product %>

      <div class="inline-flex gap-2 mt-8">
        <%= link_to "Edit", edit_product_path(@product),
          class: "rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
        <%= link_to "Back to products", products_path,
          class: "rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
        <%= button_to "Delete", product_path(@product), method: :delete,
          class: "rounded-lg py-3 px-5 bg-red-600 text-white font-medium",
          data: { confirm: "Are you sure?" } %>
      </div>
    </div>
  </div>
</div>
